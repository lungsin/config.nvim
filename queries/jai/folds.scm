; Declarations
[
  (procedure_declaration)
  (struct_declaration)
  (enum_declaration)
] @fold

; Control flow
[
  (if_statement)
  (static_if_statement)
  (else_clause)
  (for_statement)
  (while_statement)
  (if_case_statement)
] @fold

; Blocks and literals
[
  (block)
  (struct_or_union_block)
  (struct_literal)
  (anonymous_enum_type)
  (array_literal)
  (asm_statement)
  (modify_block)
] @fold

; Comments
[
  (block_comment)
] @fold
